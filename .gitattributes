*.dfm text working-tree-encoding=Shift_JIS
*.dpr text working-tree-encoding=Shift_JIS
*.cfg text working-tree-encoding=Shift_JIS
*.dof text working-tree-encoding=Shift_JIS
*.ddp text working-tree-encoding=Shift_JIS
*.dpk text working-tree-encoding=Shift_JIS
*.dproj text working-tree-encoding=Shift_JIS
*.rc text working-tree-encoding=Shift_JIS
*.ini text working-tree-encoding=Shift_JIS
